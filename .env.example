# Konect — clé API (https://konect.dev / dashboard)
KONECT_API_KEY=knct_...

# URL de base API (production par défaut ; certains déploiements utilisent une autre URL)
KONECT_BASE_URL=https://mykonect.ai/api/v1

# Comptes connectés (UUID retournés par GET /accounts)
KONECT_ACCOUNT_ID_LINKEDIN=
KONECT_ACCOUNT_ID_WHATSAPP=
KONECT_ACCOUNT_ID_INSTAGRAM=

# Airtable CRM KonectOS
AIRTABLE_API_KEY=pat...
AIRTABLE_BASE_ID=app...
